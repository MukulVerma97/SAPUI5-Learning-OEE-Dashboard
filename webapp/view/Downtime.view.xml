<mvc:View controllerName="Learning.controller.Downtime" xmlns="sap.m" xmlns:mvc="sap.ui.core.mvc" xmlns:tnt="sap.tnt" xmlns:f="sap.f" xmlns:layout="sap.ui.layout" xmlns:core="sap.ui.core">
    <Page title="Manage Downtime" showNavButton="true" navButtonPress="onPressNavButton" class="sapUiContentPadding oeePage">
        <headerContent>
            <Button icon="sap-icon://home" type="Transparent" press="onPressNavButton" tooltip="Back to OEE" />
        </headerContent>
        <content>
            <IconTabBar select="onSelect" class="sapUiSmallMarginBottom">
                <items>
                    <IconTabFilter icon="sap-icon://along-stacked-chart" iconColor="Positive" text="Minor Downtime" key="minor" count="1" />
                    <IconTabFilter icon="sap-icon://machine" iconColor="Critical" text="ALL Downtime" key="all" count="1" />
                    <IconTabFilter icon="sap-icon://quality-issue" iconColor="Negative" text="Line Down" key="line" count="1" />
                    <IconTabFilter icon="sap-icon://receipt" iconColor="Negative" text="Shared Downtime" key="shared" count="1" />
                    <IconTabFilter icon="sap-icon://accelerated" iconColor="Positive" text="Shifts Break" key="shift" count="1" />
                    <IconTabFilter icon="sap-icon://quality-issue" iconColor="Negative" text="Flow Time" key="flow" count="1" />
                </items>
            </IconTabBar>

            <Table id="om" inset="false" showSeparators="Inner" items="{/okay/}" noDataText="No downtime records found" class="sapUiSmallMarginBottom">
                <infoToolbar>
                    <OverflowToolbar>
                        <CheckBox text="Open Work" />
                        <CheckBox text="Untagged" />
                    </OverflowToolbar>
                </infoToolbar>
                <columns>
                    <Column>
                        <Text text="Work Unit" />
                    </Column>
                    <Column>
                        <Text text="Start Time" />
                    </Column>
                    <Column hAlign="Center">
                        <Text text="End Time" />
                    </Column>
                    <Column hAlign="Center">
                        <Text text="Duration" />
                    </Column>
                    <Column hAlign="Center">
                        <Text text="Type" />
                    </Column>
                    <Column hAlign="Center">
                        <Text text="Reason Code" />
                    </Column>
                    <Column hAlign="Center">
                        <Text text="Notification" />
                    </Column>
                    <Column hAlign="Center">
                        <Text text="Details" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{Work Unit}" />
                            <Text text="{Start Time}" />
                            <Text text="{End Time}" />
                            <Text text="{Duration}" />
                            <Text text="{Type}" />
                            <ObjectStatus text="{Reason Code}" state="Warning" icon="sap-icon://alert" />
                            <Text text="{Notification}" />
                            <Text text="{Details}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <footer>
            <OverflowToolbar>
                <ToolbarSpacer />
                <Button icon="sap-icon://add" text="ADD Notification" type="Transparent" class="sapUiSmallMarginEnd" />
                <Button icon="sap-icon://split" text="Split" type="Transparent" class="sapUiSmallMarginEnd" />
                <Button icon="sap-icon://arrow-top" text="Report Up" type="Transparent" class="sapUiSmallMarginEnd" />
                <Button icon="sap-icon://delete" text="Delete" type="Reject" class="sapUiSmallMarginEnd" />
                <Button icon="sap-icon://edit" text="Edit" type="Transparent" class="sapUiSmallMarginEnd" />
                <Button icon="sap-icon://add" text="Report New" type="Emphasized" press="onReport" />
                <ToolbarSpacer />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>
