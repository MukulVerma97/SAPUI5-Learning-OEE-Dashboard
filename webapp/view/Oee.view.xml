<mvc:View
    controllerName="Learning.controller.Oee"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:tnt="sap.tnt"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:l="sap.ui.layout"
    xmlns:vizFeeds="sap.viz.ui5.controls.common.feeds"
    xmlns:vizData="sap.viz.ui5.data"
    xmlns:chart="sap.suite.ui.commons"
>
    <Page showHeader="true" title="OEE Dashboard" class="oeePage sapUiContentPadding">
        <headerContent>
            <Button icon="sap-icon://value-help" id="oeeFirst" text="Hokage" type="Transparent" press=".onFirst" />
            <ToolbarSpacer />
            <Button icon="sap-icon://value-help" text="Raikage" type="Transparent" press=".onSecond" id="oeeSecond" />
            <ToolbarSpacer />
            <Button icon="sap-icon://value-help" type="Transparent" text="Kazekage" press=".onThird" id="oeeThird" />
            <ToolbarSpacer />
            <Text text="" id="oeeShowTime" class="clockText" />
        </headerContent>

        <!-- Current Shift Order Section -->
        <Panel headerText="Current Shift Order" class="sapUiSmallMarginBottom oeePanel">
            <l:Splitter>
                <VBox class="sapUiSmallMarginBegin">
                    <Title text="10000007097-0050" level="H3" class="sapUiSmallMarginBottom" />
                    <Text text="METRIC LINE PACKAGING" class="content1" />
                    <VBox height="0.5rem" />
                    <HBox>
                        <core:Icon src="sap-icon://bar-code" class="sapUiSmallMarginEnd" />
                        <Text text="Material: 10001726" class="content1" />
                    </HBox>
                    <Text text="REGENT TILE FARMHOUSE RED" class="content1" />
                    <Text text="Production Version: 001" class="content1" />
                    <Text text="Crew Size: 2.00" class="content1" />
                    <Text text="Started at: Jan 21, 2022, 1:50:00 PM" class="content1" />

                    <layoutData>
                        <l:SplitterLayoutData size="50%" resizable="false" />
                    </layoutData>
                </VBox>
                <VBox class="sapUiSmallMarginBegin">
                    <ObjectStatus text="Remaining: 16,080.00 PC" state="Warning" icon="sap-icon://pending" class="sapUiSmallMarginBottom" />
                    <VBox height="0.5rem" />
                    <ObjectStatus text="Active (Machine)" state="Success" icon="sap-icon://sys-enter-2" />
                    <VBox height="0.5rem" />
                    <Text text="Total Planned: 16,300.00 PC" class="content1" />
                    <Text text="Total Produced / Total Scrap: 220.00 PC / 10.00 PC" class="content1" />
                    <Text text="Produced in Current Shift: 0.00 PC" class="content1" />
                    <Text text="Standard Rate: 31,015.00 PC / 4.04 h" class="content1" />

                    <layoutData>
                        <l:SplitterLayoutData size="auto" />
                    </layoutData>
                </VBox>
            </l:Splitter>
        </Panel>

        <!-- KPI Section -->
        <Panel headerText="Current Shift KPIs" class="sapUiSmallMarginBottom oeePanel">
            <HBox justifyContent="SpaceAround" alignItems="Center" class="kpiContainer">
                <VBox alignItems="Center" class="kpiTile kpiAvailability">
                    <core:Icon src="sap-icon://time-entry-request" size="1.5rem" color="#107E3E" class="sapUiSmallMarginBottom" />
                    <Title text="100%" level="H2" class="kpiValue" />
                    <Text text="Availability" class="kpiLabel" />
                </VBox>
                <VBox alignItems="Center" class="kpiTile kpiSpeed">
                    <core:Icon src="sap-icon://accelerated" size="1.5rem" color="#E78C07" class="sapUiSmallMarginBottom" />
                    <Title text="0.00%" level="H2" class="kpiValue" />
                    <Text text="Speed" class="kpiLabel" />
                </VBox>
                <VBox alignItems="Center" class="kpiTile kpiQuality">
                    <core:Icon src="sap-icon://quality-issue" size="1.5rem" color="#BB0000" class="sapUiSmallMarginBottom" />
                    <Title text="0.00%" level="H2" class="kpiValue" />
                    <Text text="Quality" class="kpiLabel" />
                </VBox>
                <VBox alignItems="Center" class="kpiTile kpiOee">
                    <core:Icon src="sap-icon://performance" size="1.5rem" color="#0854A0" class="sapUiSmallMarginBottom" />
                    <Title text="0.00%" level="H2" class="kpiValue" />
                    <Text text="Overall OEE" class="kpiLabel" />
                </VBox>
            </HBox>
        </Panel>

        <!-- Untagged Section -->
        <Panel headerText="Untagged Losses" class="sapUiSmallMarginBottom oeePanel">
            <HBox justifyContent="SpaceBetween" alignItems="Center" class="untaggedBar">
                <HBox alignItems="Center">
                    <core:Icon src="sap-icon://alert" color="#E78C07" class="sapUiSmallMarginEnd" />
                    <Text text="Unaccounted Speed Loss" class="content1" />
                </HBox>
                <ObjectNumber number="09999999" unit="PC" state="Warning" />
            </HBox>
        </Panel>

        <!-- Chart Section -->
        <Panel headerText="TL-1 PACK METRIC LINE AVAILABILITY PACKAGING" class="oeePanel">
            <content>
                <viz:VizFrame height="350px" width="100%" id="idVizFrame" vizType="stacked_bar"
                    vizProperties="{
                        plotArea: {
                            colorPalette: ['#107E3E','#E78C07','#0854A0','#BB0000'],
                            dataLabel: { visible: true }
                        },
                        legend: { visible: true },
                        title: { text: 'Shift Availability Breakdown' }
                    }">
                    <viz:dataset>
                        <vizData:FlattenedDataset data="{/Reports}">
                            <vizData:dimensions>
                                <vizData:DimensionDefinition name="Shift" value="{Items}" />
                            </vizData:dimensions>
                            <vizData:measures>
                                <vizData:MeasureDefinition name="Available" value="{Available}" />
                                <vizData:MeasureDefinition name="Unscheduled" value="{Unschedule}" />
                                <vizData:MeasureDefinition name="Scheduled" value="{Schedule}" />
                                <vizData:MeasureDefinition name="Shift Basic" value="{Shift Basic}" />
                            </vizData:measures>
                        </vizData:FlattenedDataset>
                    </viz:dataset>
                    <viz:feeds>
                        <vizFeeds:FeedItem type="Measure" uid="valueAxis" values="Available,Unscheduled,Scheduled,Shift Basic" />
                        <vizFeeds:FeedItem type="Dimension" uid="categoryAxis" values="Shift" />
                    </viz:feeds>
                </viz:VizFrame>
            </content>
        </Panel>

        <!-- Footer -->
        <footer>
            <Bar>
                <contentMiddle>
                    <Link text="Report Production" class="pad" press="onReport" />
                    <Link text="Manage Downtime" class="pad" press="onDowntime" />
                    <Link text="Report Speed Loss" class="pad" press="onSpeedLoss" />
                    <Link text="Manage Order" class="pad" press="onManage" />
                    <Link text="Printing Label" press="onPrinting" class="pad" />
                </contentMiddle>
            </Bar>
        </footer>
    </Page>
</mvc:View>
