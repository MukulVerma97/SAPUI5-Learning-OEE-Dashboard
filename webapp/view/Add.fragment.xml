<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <Dialog title="Select Country" resizable="true" draggable="true" contentWidth="400px">
        <VBox class="sapUiSmallMargin">
            <Label text="Country" required="true" class="sapUiSmallMarginBottom" />
            <ComboBox id="country1" items="{/country/}" width="100%" placeholder="Select the Country">
                <items>
                    <core:Item key="{Key}" text="{Name}" />
                </items>
            </ComboBox>
        </VBox>
        <endButton>
            <Button text="Submit" icon="sap-icon://accept" press="countryClose" type="Emphasized" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
