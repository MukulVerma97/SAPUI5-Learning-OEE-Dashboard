<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <Dialog title="Product Assignment — Select Reason Code" contentWidth="750px" resizable="true" draggable="true">
        <subHeader>
            <OverflowToolbar>
                <SearchField placeholder="Search products..." liveChange=".onAssignSearch" width="100%" />
            </OverflowToolbar>
        </subHeader>
        <Table id="Assign1Frag" items="{
                path : '/ProductCollection',
                sorter : {
                    path : 'Name',
                    descending : false
                }
            }" noDataText="No products available" growing="true" growingThreshold="10"
            mode="SingleSelectLeft" selectionChange=".onAssignSelect">
            <columns>
                <Column width="12em">
                    <header>
                        <Text text="Product" />
                    </header>
                </Column>
                <Column minScreenWidth="Tablet" demandPopin="true">
                    <header>
                        <Text text="Supplier" />
                    </header>
                </Column>
                <Column minScreenWidth="Desktop" demandPopin="true" hAlign="End">
                    <header>
                        <Text text="Dimensions" />
                    </header>
                </Column>
                <Column minScreenWidth="Desktop" demandPopin="true" hAlign="Center">
                    <header>
                        <Text text="Weight" />
                    </header>
                </Column>
                <Column hAlign="End">
                    <header>
                        <Text text="Price" />
                    </header>
                </Column>
            </columns>
            <ColumnListItem vAlign="Middle" type="Active">
                <cells>
                    <ObjectIdentifier title="{Name}" text="{ProductId}" />
                    <Text text="{SupplierName}" />
                    <Text text="{Width} x {Depth} x {Height} {DimUnit}" />
                    <ObjectNumber number="{WeightMeasure}" unit="{WeightUnit}" />
                    <ObjectNumber number="{Price}" unit="{CurrencyCode}" state="Information" />
                </cells>
            </ColumnListItem>
        </Table>
        <beginButton>
            <Button press="handleClose" text="Confirm" icon="sap-icon://accept" type="Emphasized" />
        </beginButton>
        <endButton>
            <Button press="handleClose" text="Cancel" icon="sap-icon://decline" type="Transparent" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
