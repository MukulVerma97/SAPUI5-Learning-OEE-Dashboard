<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <Dialog id="onFirst" title=" Hello !!! " contentWidth="500px">
        <SearchField id="searchField1" width="100%" placeholder="Search for..." enableSuggestions="true" search=".onSearch2" suggest=".onSuggest1" suggestionItems="{ path: '/ninja'}">
            <SuggestionItem text="{Name}" key="{Name}" />
        </SearchField>
        <!-- controllerName="frag.controller.first" -->
        <!-- <subHeader>
			<OverflowToolbar>
				<SearchField liveChange=".onSearch" width="100%" />
			</OverflowToolbar>
		</subHeader> -->
        <List id="idList1" items="{/ninja}" selectionChange=".onSelectionChange1" mode="MultiSelect" growing="true" growingThreshold="50" includeItemInSelection="true">
            <infoToolbar>
                <OverflowToolbar visible="false" id="idInfoToolbar1">
                    <Label id="idFilterLabel1" />
                </OverflowToolbar>
            </infoToolbar>
            <StandardListItem title="{Name}" description="{ninjaId}" iconDensityAware="false" iconInset="false" />
        </List>
        <beginButton>
            <Button icon="sap-icon://accept" press=".onSubmit1" />
        </beginButton>
        <endButton>
            <Button icon="sap-icon://sys-cancel-2" press=".onClose1" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
