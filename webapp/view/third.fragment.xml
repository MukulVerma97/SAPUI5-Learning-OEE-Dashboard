<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <Dialog id="onThird" title=" World  !!! " contentWidth="500px">
        <SearchField id="searchField3" width="100%" placeholder="Search for..." enableSuggestions="true" search=".onSearch4" suggest=".onSuggest3" suggestionItems="{ path: '/ninja'}">
            <SuggestionItem text="{Name}" key="{Name}" />
        </SearchField>
        <List id="idList3" items="{/ninja}" selectionChange=".onSelectionChange3" mode="MultiSelect" growing="true" growingThreshold="50" includeItemInSelection="true">
            <infoToolbar>
                <OverflowToolbar visible="false" id="idInfoToolbar3">
                    <Label id="idFilterLabel3" />
                </OverflowToolbar>
            </infoToolbar>
            <StandardListItem title="{Name}" description="{ninjaId}" iconDensityAware="false" iconInset="false" />
        </List>
        <beginButton>
            <Button icon="sap-icon://accept" press=".onSubmit3" />
        </beginButton>
        <endButton>
            <Button icon="sap-icon://sys-cancel-2" press=".onClose3" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
