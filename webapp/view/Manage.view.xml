<mvc:View controllerName="Learning.controller.Manage" xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:mvc="sap.ui.core.mvc" xmlns:tnt="sap.tnt" xmlns:viz="sap.viz.ui5.controls" xmlns:chart="sap.suite.ui.commons" xmlns:vizFeeds="sap.viz.ui5.controls.common.feeds" xmlns:form="sap.ui.layout.form">
    <Page showHeader="true">
        <HBox>
            <CheckBox text="all" selected="false" id="dd" select="onSelect" />
            <CheckBox text="uchiha" selected="false" id="aa" select="onSelect" />
            <CheckBox text="uzumaki" selected="false" id="bb" select="onSelect" />
            <CheckBox text="hatake" selected="false" id="cc" select="onSelect" />
            <ToolbarSpacer />
            <Button icon="sap-icon://refresh" text="" type="Transparent" press="onPressRefresh" />
            <Button icon="sap-icon://sort" text="" type="Transparent" press=".onSecond" />
        </HBox>
        <Table items="{empData>/Rowsets/Rowset/0/Row}" id="table">
            <columns>
                <Column width="10%">
                    <Text text="Ninja Id" />
                </Column>
                <Column width="10%">
                    <Text text="Ninja Name" />
                </Column>
                <Column width="10%">
                    <Text text="Ninja House" />
                </Column>
                <Column width="10%">
                    <Text text="Signature" />
                </Column>

                <Column width="10%">
                    <Text text="Sensie" />
                </Column>
            </columns>
            <items>
                <ColumnListItem>
                    <cells>
                        <Text text="{empData>Ninja_Id}" />
                        <Text text="{empData>Ninja_Name}" />
                        <Text text="{empData>Ninja_house}" />
                        <Text text="{empData>Signatur_Jutsu}" />

                        <Text text="{empData>sensei}" />
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
    </Page>
</mvc:View>
