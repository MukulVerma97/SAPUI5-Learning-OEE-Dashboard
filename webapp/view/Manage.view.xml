<mvc:View controllerName="Learning.controller.Manage" xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:mvc="sap.ui.core.mvc" xmlns:tnt="sap.tnt">
    <Page showHeader="true" title="Manage Ninja Orders" showNavButton="true" navButtonPress="onPressNavButton" class="sapUiContentPadding oeePage">
        <headerContent>
            <Button icon="sap-icon://home" type="Transparent" press="onPressNavButton" tooltip="Back to OEE" />
        </headerContent>
        <subHeader>
            <OverflowToolbar>
                <CheckBox text="All" selected="false" id="dd" select="onSelect" />
                <CheckBox text="Uchiha" selected="false" id="aa" select="onSelect" />
                <CheckBox text="Uzumaki" selected="false" id="bb" select="onSelect" />
                <CheckBox text="Hatake" selected="false" id="cc" select="onSelect" />
                <ToolbarSpacer />
                <Button icon="sap-icon://refresh" type="Transparent" press="onPressRefresh" tooltip="Refresh" />
                <Button icon="sap-icon://sort" type="Transparent" press="onSort" tooltip="Sort" />
            </OverflowToolbar>
        </subHeader>
        <Table items="{empData>/Rowsets/Rowset/0/Row}" id="table" noDataText="No ninja records found" growing="true" growingThreshold="10" class="sapUiSmallMarginTop">
            <columns>
                <Column width="15%">
                    <Text text="Ninja Id" />
                </Column>
                <Column width="20%">
                    <Text text="Ninja Name" />
                </Column>
                <Column width="20%">
                    <Text text="Ninja House" />
                </Column>
                <Column width="25%">
                    <Text text="Signature Jutsu" />
                </Column>
                <Column width="20%">
                    <Text text="Sensei" />
                </Column>
            </columns>
            <items>
                <ColumnListItem type="Active">
                    <cells>
                        <ObjectIdentifier title="{empData>Ninja_Id}" />
                        <Text text="{empData>Ninja_Name}" class="ninja" />
                        <ObjectStatus text="{empData>Ninja_house}" state="Information" />
                        <Text text="{empData>Signatur_Jutsu}" />
                        <Text text="{empData>sensei}" />
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
    </Page>
</mvc:View>
