<mvc:View xmlns:mvc="sap.ui.core.mvc" xmlns:tnt="sap.tnt" xmlns:l="sap.ui.layout" xmlns:m="sap.m" xmlns:u="sap.ui.unified" xmlns:c="sap.ui.core" xmlns="sap.ui.table" xmlns:core="sap.ui.core" controllerName="Learning.controller.Production">
    <m:Page showHeader="true" title="Report Production" class="sapUiContentPadding oeePage">
        <!-- HEADER CONTENT -->
        <m:headerContent>
            <m:Button icon="sap-icon://value-help" id="prodFirst" text="Hokage" type="Transparent" press=".onFirst" />
            <m:ToolbarSpacer />
            <m:Button icon="sap-icon://value-help" text="Raikage" type="Transparent" press=".onSecond" id="prodSecond" />
            <m:ToolbarSpacer />
            <m:Button icon="sap-icon://value-help" type="Transparent" text="Kazekage" press=".onThird" id="prodThird" />
            <m:ToolbarSpacer />
            <m:Text text="" id="prodShowTime" class="clockText" />
        </m:headerContent>

        <!-- Current Shift Order Info -->
        <m:Panel headerText="Current Shift Order" class="sapUiSmallMarginBottom oeePanel">
            <l:Splitter>
                <m:VBox class="sapUiSmallMarginBegin">
                    <m:Title text="10000007097-0080" level="H3" class="sapUiSmallMarginBottom" />
                    <m:Text text="METRIC LINE PACKAGING" class="content1" />
                    <m:VBox height="0.5rem" />
                    <m:Text text="Material: 10001728" class="content1" />
                    <m:Text text="REGENT TILE FARMHOUSE RED" class="content1" />
                    <m:Text text="Production Version: 001" class="content1" />
                    <m:Text text="Crew Size: 2.00" class="content1" />
                    <m:Text text="Started at: Jan 21, 2022, 1:50:00 PM" class="content1" />
                    <m:layoutData>
                        <l:SplitterLayoutData size="60%" resizable="false" />
                    </m:layoutData>
                </m:VBox>
                <m:VBox class="sapUiSmallMarginBegin">
                    <m:ObjectStatus text="Remaining: 18,080.00 PC" state="Warning" icon="sap-icon://pending" />
                    <m:VBox height="0.5rem" />
                    <m:ObjectStatus text="Active (Machine)" state="Success" icon="sap-icon://sys-enter-2" />
                    <m:VBox height="0.5rem" />
                    <m:Text text="Total Planned: 18,800.00 PC" class="content1" />
                    <m:Text text="Total Produced / Total Scrap: 220.00 PC / 10.00 PC" class="content1" />
                    <m:Text text="Produced in Current Shift: 0.00 PC" class="content1" />
                    <m:Text text="Standard Rate: 81,018.00 PC / 4.04 h" class="content1" />
                    <m:layoutData>
                        <l:SplitterLayoutData size="auto" />
                    </m:layoutData>
                </m:VBox>
            </l:Splitter>
        </m:Panel>

        <!-- Production Data Table -->
        <m:Panel headerText="Production Data" class="oeePanel">
            <Table rows="{/ProductCollection}" visibleRowCount="3" id="prodTable">
                <columns>
                    <Column width="8rem">
                        <m:Label text="Parameter" />
                        <template>
                            <m:Text text="{Name}" wrapping="false" />
                        </template>
                    </Column>
                    <Column width="8rem">
                        <m:Label text="Quantity" />
                        <template>
                            <m:Input width="7rem" />
                        </template>
                    </Column>
                    <Column width="8rem">
                        <m:Label text="UOM" />
                        <template>
                            <m:Button icon="sap-icon://value-help" id="prodUom" text="PC" type="Transparent" press=".onFirst" />
                        </template>
                    </Column>
                    <Column width="8rem">
                        <m:Label text="Reason Code" />
                        <template>
                            <m:Button text="{reason}" icon="{icon}" press="openTable" />
                        </template>
                    </Column>
                    <Column width="8rem">
                        <m:Label text="Comments" />
                        <template>
                            <m:Button text="{comments}" icon="{icon}" press="openCombo" />
                        </template>
                    </Column>
                    <Column width="8rem">
                        <m:Label text="Details" />
                        <template>
                            <m:Button icon="sap-icon://inspection" text="Details" type="Transparent" press="showPdf" />
                        </template>
                    </Column>
                    <Column width="8rem">
                        <m:Label text="Report Qty per Shift" />
                        <template>
                            <m:Text text="{Shift}" wrapping="false" />
                        </template>
                    </Column>
                </columns>
            </Table>
        </m:Panel>

        <m:footer>
            <m:Bar>
                <m:contentRight>
                    <m:Button text="Save" icon="sap-icon://save" press="showPdf" id="prodSave" type="Emphasized" />
                </m:contentRight>
            </m:Bar>
        </m:footer>
    </m:Page>
</mvc:View>
