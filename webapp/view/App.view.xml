<mvc:View xmlns:tnt="sap.tnt" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:core="sap.ui.core" controllerName="Learning.controller.App">
    <tnt:ToolPage id="mainPage" class="navigate">
        <tnt:header>
            <tnt:ToolHeader>
                <Button icon="sap-icon://menu" press="openSide" />

                <ToolbarSpacer />
                <ToolbarSpacer />

                <Title text="Nauruto Hidden Village" />
                <ToolbarSpacer />
                <Button icon="sap-icon://sys-help" press="onHelp" />

                <MenuButton text="Hi User" type="Transparent" icon="sap-icon://employee-lookup">
                    <layoutData>
                        <OverflowToolbarLayoutData priority="NeverOverflow" />
                    </layoutData>
                    <Menu>
                        <MenuItem text="Log Out" icon="sap-icon://log" />
                    </Menu>
                </MenuButton>
            </tnt:ToolHeader>
        </tnt:header>

        <tnt:sideContent>
            <tnt:SideNavigation itemSelect="onItemSelect" id="sideNavigate" class="navigate" expanded="true">
                <tnt:NavigationList id="navigationList" class="navigate">
                    <tnt:NavigationListItem text="OEE Dashboard" id="Oee" icon="sap-icon://cart-full" key="Oee" />
                    <tnt:NavigationListItem text="Manage Order" icon="sap-icon://home" key="Manage" />
                    <tnt:NavigationListItem text="Report Production" id="production" icon="sap-icon://accelerated" key="Production" />
                    <tnt:NavigationListItem text="Manage Downtime" id="downtime" icon="sap-icon://employee" key="Downtime" />
                    <tnt:NavigationListItem text="Report Speed Loss" id="report" icon="sap-icon://cart-full" key="SpeedLoss" />
                </tnt:NavigationList>
            </tnt:SideNavigation>
        </tnt:sideContent>
        <tnt:mainContents>
            <App id="app">
                <mvc:XMLView viewName="Learning.view.Oee" />
            </App>

            <NavContainer />
        </tnt:mainContents>
    </tnt:ToolPage>

    <!-- <mvc:XMLView viewName="Learning.view.Tree" /> -->

    <!-- <mvc:XMLView viewName="Learning.view.Header" /> -->
</mvc:View>
